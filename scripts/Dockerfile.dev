FROM rust:1-bookworm

# System libs required to build the full workspace including prdt-client
# (the unified host+viewer binary released via release.yml).
#
# Categorization:
# - PipeWire 0.9: libpipewire-0.3-dev pulls libspa-0.2-dev transitively
#   but pin it explicitly so a future apt change can't strip it.
# - GUI host (tray-icon -> muda -> libxdo, plus gtk/atk/pango/etc.):
#   gui-host became an unconditional dep of prdt-host in commit fb8519f
#   (P5B-1 successor "unify consent types"), so Linux release builds
#   now need the full GTK3 stack + libxdo. Keep this list in sync with
#   .github/workflows/release.yml's apt list.
# - Audio (cpal/audiopus): libasound2-dev + cmake.
# ---- CUDA + NPP dev libs (NVIDIA repo, headers + import libs only) ----
# Optional dependency for the ffmpeg-encode-hevc-nvenc-npp feature.
# We pull from NVIDIA's official CUDA apt repo because Debian 12
# contrib only ships NPP *runtime* libs, not -dev headers.
# No nvcc / nvrtc / driver pulled — runtime CUDA is exercised only by
# #[ignore]'d real-HW tests on the smoke runner, never on this image.
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends \
      ca-certificates curl gnupg \
 && curl -fsSL https://developer.download.nvidia.com/compute/cuda/repos/debian12/x86_64/cuda-keyring_1.1-1_all.deb \
      -o /tmp/cuda-keyring.deb \
 && dpkg -i /tmp/cuda-keyring.deb \
 && rm /tmp/cuda-keyring.deb \
 && apt-get update -qq \
 && apt-get install -y -qq --no-install-recommends \
      cuda-cudart-dev-12-4 \
      libnpp-dev-12-4 \
 && rm -rf /var/lib/apt/lists/*
# Pin to CUDA 12.4 toolkit (matches NVIDIA driver >= 535 floor per
# P1.5 A8 — driver 535 supports up to CUDA 12.2 forward-compat, and
# CUDA 12.4 runtime works against driver 535+ via forward compat).
# If NVIDIA bumps the keyring URL or drops 12-4 packages, bump these
# two version suffixes; everything else stays put.

RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends \
        libpipewire-0.3-dev \
        libspa-0.2-dev \
        libva-dev libva-drm2 libva-x11-2 \
        libavcodec-dev libavutil-dev libavfilter-dev libavformat-dev \
        libavdevice-dev libswresample-dev libswscale-dev \
        libasound2-dev \
        libgtk-3-dev libpango1.0-dev libcairo2-dev \
        libgdk-pixbuf-2.0-dev libatk1.0-dev libayatana-appindicator3-dev \
        libxdo-dev \
        libglib2.0-dev libdbus-1-dev \
        libxcb-shm0-dev libxcb-randr0-dev libxcb-xfixes0-dev \
        libxkbcommon-dev libwayland-dev libssl-dev \
        cmake \
        pkg-config \
        build-essential \
        clang \
        libclang-dev && \
    rm -rf /var/lib/apt/lists/*

# Bake in rustfmt and clippy so ephemeral container invocations have them.
RUN rustup component add rustfmt clippy

# Cargo cache mount and target dir come in from the host at runtime
# (see scripts/dev-container.sh). The image itself stays small.
